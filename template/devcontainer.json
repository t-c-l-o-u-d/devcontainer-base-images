{
  "name": "devcontainer-${localWorkspaceFolderBasename}",
  "build": {
    "dockerfile": "Containerfile",
    "args": {
      "USER": "${localEnv:USER}"
    },
    "options": [
      "--pull=always",
      "--squash-all"
    ]
  },
  "remoteUser": "${localEnv:USER}",
  "updateRemoteUserUID": true,
  "workspaceMount": "",
  "runArgs": [
    "--env=TZ=America/Chicago",
    "--hostname=devcontainer-${localWorkspaceFolderBasename}",
    "--name=devcontainer-${localWorkspaceFolderBasename}",
    "--userns=keep-id",
    "--volume=${localWorkspaceFolder}:/workspaces/${localWorkspaceFolderBasename}:Z,rw",
    "--volume=${localEnv:HOME}/.bashrc:/home/${localEnv:USER}/.bashrc:Z,ro"
  ],
  "customizations": {
    "vscode": {
      "settings": {
        "breadcrumbs.enabled": true,
        "editor.minimap.enabled": false,
        "editor.stickyScroll.enabled": false,
        "git.autofetch": true,
        "git.confirmSync": false,
        "workbench.startupEditor": "none",
        "workbench.welcomePage.walkthroughs.openOnInstall": false,
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "/usr/bin/bash"
          }
        },
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "ms-azuretools.vscode-containers"
      ]
    }
  }
}
